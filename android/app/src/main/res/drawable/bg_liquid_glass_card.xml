<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow layer -->
    <item android:left="-1dp" android:top="-1dp" android:right="-1dp" android:bottom="-1dp">
        <shape android:shape="rectangle">
            <corners android:radius="21dp" />
            <stroke android:width="1dp" android:color="#20FFFFFF" />
        </shape>
    </item>
    <!-- Glass background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:startColor="#18FFFFFF"
                android:centerColor="#12FFFFFF"
                android:endColor="#18FFFFFF"
                android:angle="90" />
            <stroke android:width="1dp" android:color="#25FFFFFF" />
        </shape>
    </item>
</layer-list>