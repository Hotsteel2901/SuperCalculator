<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/sc_void"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="3D Surface - Full Screen"
            app:titleTextColor="@color/m3_on_surface" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.supercalc.Surface3DView
            android:id="@+id/full_screen_3d_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/coordinate_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@color/glass_card_bg"
            android:padding="8dp"
            android:textColor="@color/m3_on_surface"
            android:textSize="16sp"
            android:fontFamily="@font/jetbrains_mono"
            android:text="@string/surface_hint"
            android:visibility="visible" />

    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_exit_3d"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:text="@string/exit_full_screen"
        android:fontFamily="@font/jetbrains_mono"
        android:textSize="14sp"
        app:cornerRadius="12dp" />

</LinearLayout>
